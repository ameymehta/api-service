{
  "name": "api-service",
  "version": "1.0.0",
  "private": true,
  "description": "API Service",
  "main": "index.ts",
  "scripts": {
    "build": "tsc && export NODE_ENV=test && gulp",
    "start": "npm run build && export NODE_ENV=dev && nodemon index.ts",
    "prod": "export NODE_ENV=production && tsc && ts-node index.ts",
    "test": "tsc && export NODE_ENV=test && mocha -r ts-node/register --exit tests/*.ts",
    "coverage": "nyc --reporter html --reporter text -e .ts npm run test"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/register": "^7.28.6",
    "@types/express": "^4.17.25",
    "body-parser": "^1.20.4",
    "compression": "^1.8.1",
    "date-format-utils": "^2.2.0",
    "express": "^4.22.1",
    "express-validator": "^7.2.1",
    "fs-sync": "^1.0.7",
    "lodash": "^4.18.1",
    "log4js": "^6.9.1",
    "merge": "^2.1.1",
    "nconf": "^0.12.0",
    "node-fetch": "^2.7.0",
    "redis": "^4.7.0",
    "string-format": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/chai": "^4.3.14",
    "@types/mocha": "^10.0.7",
    "@types/nconf": "^0.10.7",
    "@types/sinon": "^21.0.0",
    "@types/string-format": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "chai": "^4.4.1",
    "chai-as-promised": "^7.1.1",
    "chai-http": "^4.4.0",
    "eslint": "^8.57.1",
    "gulp": "^4.0.2",
    "gulp-eslint-new": "^2.6.2",
    "gulp-mocha": "^9.0.0",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.14",
    "nyc": "^15.1.0",
    "sinon": "^21.0.3"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "serialize-javascript": "^7.0.5"
  }
}
