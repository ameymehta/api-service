{
    "compilerOptions": {
      "module": "commonjs",
      "target": "ES2019",
      "noImplicitAny": true,
      "sourceMap": true,
      "outDir": "build",
      "baseUrl": ".",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "types": ["node"],
      "paths": {
        "*": ["node_modules/*"]
      },
      "ignoreDeprecations": "6.0",
    },
    "include": [
      "**/*"
    ],
    "exclude": [
      "node_modules"
    ]
}